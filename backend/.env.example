# Copy this file to .env and fill in real values. Never commit .env to git.

# Leave DATABASE_URL unset to use SQLite (zero setup, good for development).
# For the final with PostgreSQL, uncomment and edit:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/carecompass

# Required for JWT signing. Set a long random value in production.
# SECRET_KEY=change-me-in-production

# Required for the AI chat stretch feature (website floating assistant) and
# the Chrome extension's Browser Guide. Keep this on the backend; never add
# it to manifest.json or extension JavaScript.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_FALLBACK_MODEL=gemini-3-flash-preview

# Optional. The NYC benefits directory works without a token, but a free
# Socrata app token gives the deployed API higher request limits.
# NYC_OPEN_DATA_APP_TOKEN=
# NYC_BENEFITS_API_URL=https://data.cityofnewyork.us/resource/kvhd-5fmu.json
