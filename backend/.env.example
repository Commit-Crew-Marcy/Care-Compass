# Copy this file to .env and fill in real values. Never commit .env to git.

# Leave DATABASE_URL unset to use SQLite (zero setup, good for development).
# For the final with PostgreSQL, uncomment and edit:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/carecompass

# Required for JWT signing. Set a long random value in production.
# SECRET_KEY=change-me-in-production

# Required only for the AI chat stretch feature:
# ANTHROPIC_API_KEY=sk-ant-...
