# Copy this file to .env.local and fill in real values.
# Never commit .env or .env.local to git.

# Optional override for the backend API base URL. If unset, dev mode uses
# http://localhost:8000 and a production build uses the deployed Render URL.
VITE_API_BASE_URL=http://localhost:8000
# Optional after the Chrome Web Store listing is published. Until then the
# website prompt links to this repository's local installation instructions.
# VITE_EXTENSION_INSTALL_URL=https://chromewebstore.google.com/detail/your-listing-id
